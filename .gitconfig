[core]
    editor = nvim
    pager = delta

[user]
	name = 1zumiSagiri
	email = iizumisagiri@icloud.com

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    side-by-side = true
    true-color = always

[merge]
    conflictStyle = zdiff3

[submodule]
	recurse = true
[init]
	defaultBranch = master
[commit]
	gpgsign = true
